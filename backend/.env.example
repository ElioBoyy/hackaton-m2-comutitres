# Variables d'environnement du backend (copier en .env et renseigner les cles).
# Charge par Spring via spring.config.import dans application.yml (format .properties :
# une ligne CLE=valeur). Le .env reel est gitignore : ne jamais committer de cle.
#
# En prod, ces valeurs viennent de l'environnement du conteneur, pas d'un fichier.

# --- Voyage AI : embeddings (https://docs.voyageai.com) ---
# Cle au prefixe pa-... Sert a l'ingestion du corpus et a la recherche.
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Mistral : generation des reponses (https://docs.mistral.ai) ---
# Sans cette cle, l'ingestion et la recherche marchent, mais l'assistant ne peut
# pas rediger de reponse (l'API renvoie alors une erreur claire a l'appel).
MISTRAL_API_KEY=

# Copier en .env A COTE de compose.prod.yaml sur le VPS, puis renseigner.
# Les valeurs BACKEND_IMAGE / FRONTEND_IMAGE sont ecrasees par la CI a chaque
# deploy (elle ecrit le tag exact), mais doivent exister au premier lancement.

POSTGRES_DB=jegeremacartenavigo
POSTGRES_USER=jgmcn
POSTGRES_PASSWORD=change-me

# Origine publique du frontend, pour le CORS du backend.
FRONTEND_ORIGIN=https://votre-domaine.example

# Images GHCR (tag inclus). Renseignees/mises a jour par la CI.
BACKEND_IMAGE=ghcr.io/elioboyy/hackaton-backend:latest
FRONTEND_IMAGE=ghcr.io/elioboyy/hackaton-frontend:latest

# --- MinIO (pieces justificatives, bucket prive cree par le backend) ---
# Le backend re-stream les objets via /fichiers/contenu apres verif JWT :
# pas besoin d'exposer publiquement MinIO, ni de publier ses ports.
MINIO_ROOT_USER=jgmcn
MINIO_ROOT_PASSWORD=change-me-too
